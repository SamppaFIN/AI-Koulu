---
import { getCollection, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";

type Props = {
  entry: CollectionEntry<"agent-patterns">;
};

export async function getStaticPaths() {
  const chapters = await getCollection("agent-patterns");
  return chapters.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.description} entry={entry}>
  <article class="container-content" style="padding-block: var(--space-3xl);">
    <div class="chapter-header" style="margin-bottom: var(--space-2xl);">
      <p class="chapter-tag" style="color: var(--color-brand); font-weight: 600; margin-bottom: var(--space-xs);">
        {entry.data.section}
      </p>
      <h1 style="color: var(--color-text); font-size: clamp(1.8rem, 3vw, 2.4rem);">
        {entry.data.title}
      </h1>
      <p style="color: var(--color-text-secondary); font-size: 1.1rem;">
        {entry.data.description}
      </p>
    </div>

    <div class="prose" style="
      max-width: 72ch;
      margin-inline: auto;
      font-size: 1.05rem;
      line-height: 1.8;
    ">
      <Content />
    </div>

    <nav style="
      margin-top: var(--space-3xl);
      padding-top: var(--space-xl);
      border-top: 1px solid var(--glass-border);
      display: flex;
      justify-content: space-between;
    ">
      <a href="/AI-Koulu/agent-patterns/" style="color: var(--color-brand); text-decoration: none; font-weight: 500;">
        ← Takaisin osion etusivulle
      </a>
    </nav>
  </article>
</Layout>
