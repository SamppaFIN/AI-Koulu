---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { ChapterProgress } from "../../components/ProgressTracker.tsx";

const chapters = await getCollection("ai-architecture");
const sorted = chapters.sort((a, b) => a.data.order - b.data.order);
---

<Layout title="AI-arkkitehtuurit" description="Nykyajan AI-kehityksen ohjelmistoarkkitehtuurimallit">
  <section class="container-content" style="padding-block: var(--space-3xl);">
    <ChapterProgress items={sorted.map(c => ({ id: c.slug, title: c.data.title }))} basePath="ai-architecture" client:visible />

    <h1 style="color: var(--color-brand);">AI-arkkitehtuurit</h1>
    <p style="color: var(--color-text-secondary); font-size: 1.2rem; margin-bottom: var(--space-2xl);">
      Nykyajan AI-kehityksen ohjelmistoarkkitehtuurimallit — API-kääreistä agenttijärjestelmiin.
    </p>

    <div style="
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--space-md);
    ">
      {sorted.map((chapter) => (
        <a href={`/AI-Koulu/ai-architecture/${chapter.slug}/`} class="chapter-link">
          <article class="chapter-card">
            <span class="chapter-badge">Luku {chapter.data.order}</span>
            <div class="chapter-body">
              <h2>{chapter.data.title}</h2>
              <p>{chapter.data.description}</p>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style is:global>
  .chapter-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .chapter-card {
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border);
    border-radius: 14px;
    padding: var(--space-xl);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.3s ease,
                border-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }
  .chapter-card::before {
    content: '';
    position: absolute;
    top: 0; left: -100%;
    width: 100%; height: 100%;
    background: linear-gradient(90deg, transparent, oklch(1 0 0 / 0.06), transparent);
    animation: cardGlow 4s linear infinite;
    pointer-events: none;
  }
  .chapter-link:hover .chapter-card {
    transform: translateY(-3px) scale(1.01);
    box-shadow: 0 12px 40px oklch(0 0 0 / 0.15);
    border-color: var(--color-brand-light);
  }
  .chapter-badge {
    display: inline-flex;
    align-items: center;
    min-width: 2rem;
    height: 1.6rem;
    font-size: 0.75rem;
    font-weight: 800;
    color: white;
    background: var(--aurora-gradient-1);
    padding: 0 0.5rem;
    border-radius: 999px;
    white-space: nowrap;
    flex-shrink: 0;
    box-shadow: 0 2px 8px oklch(0.55 0.24 280 / 0.25);
  }
  .chapter-body h2 {
    margin: 0 0 var(--space-xs) 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text);
  }
  .chapter-body p {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.6;
  }
</style>
