---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import Callout from "../../components/ui/Callout.tsx";
import AnalogyBox from "../../components/ui/AnalogyBox.tsx";
import WhyItMatters from "../../components/ui/WhyItMatters.tsx";
import Reference from "../../components/ui/Reference.tsx";
import Diagram from "../../components/ui/Diagram.tsx";
import TokenizerDemo from "../../components/demo/TokenizerDemo.tsx";
import RAGPlayground from "../../components/demo/RAGPlayground.tsx";
import AgentSimulation from "../../components/demo/AgentSimulation.tsx";
import MultimodalComparison from "../../components/demo/MultimodalComparison.tsx";
import ProgressWrapper from "../../components/ProgressWrapper.tsx";

export async function getStaticPaths() {
  const chapters = await getCollection("ai-architecture");
  return chapters.map((chapter) => ({
    params: { slug: chapter.slug },
    props: { chapter },
  }));
}

const { chapter } = Astro.props;
const { Content } = await chapter.render();
const mdxComponents = { Callout, AnalogyBox, WhyItMatters, Reference, Diagram, TokenizerDemo, RAGPlayground, AgentSimulation, MultimodalComparison };
---

<Layout title={chapter.data.title} description={chapter.data.description} entry={chapter}>
  <article class="container-content" style="padding-block: var(--space-2xl);">
    <!-- Otsikko -->
    <header style="margin-bottom: var(--space-2xl);">
      <p style="
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--color-brand);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: var(--space-sm);
      ">
        Luku {chapter.data.order} — {chapter.data.section}
      </p>
      <h1 style="margin: 0 0 var(--space-sm) 0;">{chapter.data.title}</h1>
      <p style="color: var(--color-text-secondary); font-size: 1.1rem; margin: 0;">
        {chapter.data.description}
      </p>
    </header>

    <!-- Varsinainen sisältö (MDX renderöitynä) -->
    <div class="mdx-content">
      <Content components={mdxComponents} />
    </div>

    <!-- Navigaatio seuraavaan/edelliseen -->
    <nav style="
      display: flex;
      justify-content: space-between;
      margin-top: var(--space-3xl);
      padding-top: var(--space-xl);
      border-top: 1px solid var(--color-border);
    ">
      <span></span>
      <a href="/AI-Koulu/ai-architecture/" style="
        color: var(--color-brand);
        text-decoration: none;
        font-weight: 500;
      ">
        ← Takaisin sisällykseen
      </a>
    </nav>
  </article>
  <ProgressWrapper slug={chapter.slug} client:visible />
</Layout>

<style is:global>
  .mdx-content h2 {
    margin-top: var(--space-2xl);
    color: var(--color-brand-dark);
  }
  .mdx-content h3 {
    margin-top: var(--space-xl);
  }
  .mdx-content p {
    margin-block: var(--space-md);
  }
  .mdx-content ul, .mdx-content ol {
    margin-block: var(--space-md);
    padding-left: var(--space-lg);
  }
  .mdx-content li {
    margin-block: var(--space-xs);
  }
  .mdx-content code {
    background: var(--color-bg-code);
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    font-size: 0.85em;
  }
  .mdx-content pre {
    background: var(--color-bg-code);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: var(--space-md);
    overflow-x: auto;
    margin-block: var(--space-lg);
  }
  .mdx-content pre code {
    background: none;
    padding: 0;
  }
  .mdx-content blockquote {
    border-left: 4px solid var(--color-brand-light);
    padding-left: var(--space-lg);
    margin-block: var(--space-lg);
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .mdx-content a {
    color: var(--color-brand);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .mdx-content a:hover {
    color: var(--color-brand-dark);
  }
  .mdx-content img {
    max-width: 100%;
    border-radius: 8px;
    margin-block: var(--space-lg);
  }
  .mdx-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin-block: var(--space-2xl);
  }
  .mdx-content table {
    width: 100%;
    border-collapse: collapse;
    margin-block: var(--space-lg);
  }
  .mdx-content th, .mdx-content td {
    padding: var(--space-sm) var(--space-md);
    border: 1px solid var(--color-border);
    text-align: left;
  }
  .mdx-content th {
    background: var(--color-bg-card);
    font-weight: 600;
  }
</style>
