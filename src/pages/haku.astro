---
import Layout from "../layouts/Layout.astro";
import SearchBar from "../components/SearchBar.tsx";
---

<Layout title="Haku" description="Hae AI-arkkitehtuurien ja UI/UX-käytäntöjen oppaista">
  <section class="container-content" style="padding-block: var(--space-3xl);">
    <h1 style="color: var(--color-brand);">Haku</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: var(--space-2xl);">
      Hae koko sivuston sisällöstä — oppaista, käsitteistä ja esimerkeistä.
    </p>

    <div style="max-width: 600px;">
      <SearchBar client:visible />
    </div>
  </section>
</Layout>
    </div>
  </section>
</Layout>
