---
import type { CollectionEntry } from "astro:content";
import AuroraBackground from "../components/ui/AuroraBackground.tsx";

export interface Props {
  title: string;
  description?: string;
  /** Content collection entry for table of contents */
  entry?: CollectionEntry<"ai-architecture"> | CollectionEntry<"ui-ux">;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="fi" data-theme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? "AI-arkkitehtuurit & UI/UX-käytännöt - opetussivusto"} />
    <title>{title} | AI & UI/UX Edu</title>

    <!-- Fontit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Globaalit tyylit -->
    <link rel="stylesheet" href="/src/styles/globals.css" />

    <!-- Teema-skripti (suoritetaan ennen renderöintiä flashin estämiseksi) -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('ai-edu-theme') || 'system';
        var root = document.documentElement;
        if (theme === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        root.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <AuroraBackground client:visible />

    <!-- Yläpalkki -->
    <header class="container-wide" style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-block: var(--space-md);
      border-bottom: 1px solid var(--color-border);
      position: sticky;
      top: 0;
      z-index: 100;
      background: var(--color-bg);
    ">
      <!-- Logo -->
      <a href="/AI-Koulu/" style="
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--color-brand);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      ">
        <span style="font-size: 1.5rem;">⚡</span>
        AI & UI/UX Edu
      </a>

      <!-- Navigaatio -->
      <nav aria-label="Päänavigaatio" style="display: flex; align-items: center; gap: var(--space-lg);">
        <a href="/AI-Koulu/ai-architecture/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          AI-arkkitehtuurit
        </a>
        <a href="/AI-Koulu/ui-ux/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          UI/UX-käytännöt
        </a>
        <a href="/AI-Koulu/haku/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          Haku
        </a>

        <!-- Teemanvaihtaja -->
        <button
          id="theme-toggle"
          aria-label="Vaihda teemaa"
          style="
            background: none;
            border: 1px solid var(--color-border);
            border-radius: 999px;
            padding: 0.5rem 0.75rem;
            cursor: pointer;
            color: var(--color-text);
            font-size: 1rem;
            line-height: 1;
          "
        >
          🌓
        </button>
      </nav>
    </header>

    <!-- Pääsisältö -->
    <main>
      <slot />
    </main>

    <!-- Alaosa -->
    <footer class="container-wide" style="
      border-top: 1px solid var(--color-border);
      padding-block: var(--space-xl);
      margin-top: var(--space-3xl);
      text-align: center;
      color: var(--color-text-muted);
      font-size: 0.875rem;
    ">
      <p>
        <strong>AI & UI/UX Edu</strong> — Interaktiivinen opetussivusto AI-arkkitehtuureista ja UI/UX-käytännöistä.
      </p>
      <p style="margin-top: var(--space-sm);">
        Sisältö perustuu vuoden 2024–2026 tutkimukseen. Lähdeviitteet jokaisen luvun yhteydessä.
      </p>
    </footer>

    <!-- Teemanvaihtaja-skripti -->
    <script>
      import { getStoredTheme, setTheme, applyTheme, watchSystemTheme } from "../lib/theme.ts";

      const toggle = document.getElementById("theme-toggle");
      if (toggle) {
        toggle.addEventListener("click", () => {
          const current = getStoredTheme();
          const cycles: Record<string, string> = { light: "dark", dark: "system", system: "light" };
          const next = cycles[current] || "light";
          setTheme(next as any);
          toggle.setAttribute("aria-label", `Teema: ${next}`);
        });
      }

      // Reagoi järjestelmän teeman muutoksiin
      const cleanup = watchSystemTheme();

      // Siivous (ei tarvetta, mutta pattern)
      document.addEventListener("astro:before-swap", cleanup);
    </script>
  </body>
</html>
