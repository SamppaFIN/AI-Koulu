---
import type { CollectionEntry } from "astro:content";
import AuroraBackground from "../components/ui/AuroraBackground.tsx";

export interface Props {
  title: string;
  description?: string;
  /** Content collection entry for table of contents */
  entry?: CollectionEntry<"ai-architecture"> | CollectionEntry<"ui-ux">;
}

const { title, description } = Astro.props;

const aiChapters = [
  { num: "1", title: "Johdanto", slug: "ai-architecture/01-johdanto", hasDemo: "tokenisointi" },
  { num: "2.1", title: "API-kääremallit", slug: "ai-architecture/02-1-api-wrappers" },
  { num: "2.2", title: "RAG", slug: "ai-architecture/02-2-rag", hasDemo: "📚 leikkikenttä", hasDiagram: "🔗 kaavio" },
  { num: "2.3", title: "Agentit", slug: "ai-architecture/02-3-agents", hasDemo: "🤖 simulointi" },
  { num: "2.4", title: "Hienosäätö", slug: "ai-architecture/02-4-finetuning" },
  { num: "2.5", title: "Multimodaali", slug: "ai-architecture/02-5-multimodal", hasDemo: "🖼️ vertailu" },
  { num: "2.6", title: "Hybridi", slug: "ai-architecture/02-6-hybrid" },
  { num: "3", title: "Infrastruktuuri", slug: "ai-architecture/03-infrastructure" },
  { num: "4", title: "Suunnitteluperiaatteet", slug: "ai-architecture/04-design-principles" },
  { num: "5", title: "Viitearkkitehtuurit", slug: "ai-architecture/05-reference-architectures" },
];

const agentPatternChapters = [
  { num: "1", title: "LLM-agenttisuunnittelumallit", slug: "agent-patterns/01-llm-agent-patterns" },
];

const uxChapters = [
  { num: "1", title: "HCD", slug: "ui-ux/01-hcd" },
  { num: "2", title: "Visuaaliset trendit", slug: "ui-ux/02-visual-trends", hasDemo: "🎨 kontrasti" },
  { num: "3", title: "IxD", slug: "ui-ux/03-interaction-design", hasDemo: "🎯 Hickin laki" },
  { num: "4", title: "Saavutettavuus", slug: "ui-ux/04-accessibility", hasDemo: "♿ a11y-labra" },
  { num: "5", title: "Suorituskyky", slug: "ui-ux/05-performance", hasDemo: "📐 CLS + 💀 skeleton" },
  { num: "6", title: "Modernit UI", slug: "ui-ux/06-modern-ui" },
  { num: "7", title: "AI & UI/UX", slug: "ui-ux/07-ai-ux" },
  { num: "8", title: "UX-tutkimus", slug: "ui-ux/08-ux-research" },
  { num: "9", title: "Työkalut", slug: "ui-ux/09-tools" },
];
---

<!doctype html>
<html lang="fi" data-theme="system">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description ?? "AI-arkkitehtuurit & UI/UX-käytännöt - opetussivusto"} />
    <title>{title} | AI & UI/UX Edu</title>

    <!-- Fontit -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Globaalit tyylit -->
    <link rel="stylesheet" href="/AI-Koulu/styles/site.css" />

    <!-- Teema-skripti (suoritetaan ennen renderöintiä flashin estämiseksi) -->
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('ai-edu-theme') || 'system';
        var root = document.documentElement;
        if (theme === 'system') {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        root.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <AuroraBackground client:visible />

    <!-- Yläpalkki -->
    <header class="container-wide header-glass" style="
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding-block: var(--space-md);
    ">
      <!-- Logo -->
      <a href="/AI-Koulu/" style="
        font-weight: 800;
        font-size: 1.25rem;
        color: var(--color-brand);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      ">
        <span style="font-size: 1.5rem;">⚡</span>
        AI & UI/UX Edu
      </a>

      <!-- Navigaatio -->
      <nav class="desktop-nav" aria-label="Päänavigaatio" style="display: flex; align-items: center; gap: var(--space-lg);">
        <a href="/AI-Koulu/ai-architecture/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          AI-arkkitehtuurit
        </a>
        <a href="/AI-Koulu/agent-patterns/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          Agenttisuunnittelumallit
        </a>
        <a href="/AI-Koulu/ui-ux/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          UI/UX-käytännöt
        </a>
        <a href="/AI-Koulu/haku/" style="color: var(--color-text-secondary); text-decoration: none; font-weight: 500;">
          Haku
        </a>

        <!-- Teemanvaihtaja -->
        <button
          data-theme-btn
          aria-label="Vaihda teemaa"
          style="
            background: none;
            border: 1px solid var(--color-border);
            border-radius: 999px;
            padding: 0.5rem 0.75rem;
            cursor: pointer;
            color: var(--color-text);
            font-size: 1rem;
            line-height: 1;
          "
        >
          🌓
        </button>
      </nav>

      <!-- Hampurilaisvalikko-painike (mobiili) -->
      <button
        id="hamburger-btn"
        class="hamburger-btn"
        aria-label="Avaa valikko"
        aria-expanded="false"
      >
        ☰
      </button>
    </header>

    <!-- Mobiilivalikko (hampurilainen) -->
    <div id="mobile-menu-overlay" class="mobile-menu-overlay"></div>
    <nav id="mobile-menu" class="mobile-menu" aria-label="Mobiilivalikko">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <span style="font-weight: 800; color: var(--color-brand);">⚡ AI & UI/UX</span>
        <button id="close-menu" style="background: none; border: none; font-size: 1.5rem; cursor: pointer; color: var(--color-text); padding: 0.5rem;">✕</button>
      </div>

      <!-- Pikalinkit -->
      <a href="/AI-Koulu/" style="display: block; padding: 0.6rem 0.8rem; border-radius: 8px; font-weight: 700; font-size: 1rem; color: var(--color-brand); text-decoration: none;">🏠 Etusivu</a>

      <!-- AI-arkkitehtuurit -->
      <details style="margin-top: 0.25rem;">
        <summary style="padding: 0.6rem 0.8rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; cursor: pointer; color: var(--color-text);">🤖 AI-arkkitehtuurit</summary>
        <div style="margin-left: 0.5rem; border-left: 2px solid var(--color-border); padding-left: 0.5rem;">
          {aiChapters.map(ch => (
            <a href={`/AI-Koulu/${ch.slug}/`} style="display: flex; align-items: center; gap: 0.3rem; padding: 0.45rem 0.8rem; border-radius: 6px; color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;">
              <span style="font-size: 0.7rem; color: var(--color-brand); min-width: 1.8rem;">{ch.num}</span>
              <span>{ch.title}</span>
              {ch.hasDiagram && <span style="font-size: 0.7rem; margin-left: auto;" title="Kaavio">{ch.hasDiagram}</span>}
              {ch.hasDemo && <span style="font-size: 0.7rem; margin-left: auto;" title="Interaktiivinen demo">{ch.hasDemo}</span>}
            </a>
          ))}
        </div>
      </details>

      <!-- Agenttisuunnittelumallit -->
      <details style="margin-top: 0.25rem;">
        <summary style="padding: 0.6rem 0.8rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; cursor: pointer; color: var(--color-text);">🧠 Agenttisuunnittelumallit</summary>
        <div style="margin-left: 0.5rem; border-left: 2px solid var(--color-border); padding-left: 0.5rem;">
          {agentPatternChapters.map(ch => (
            <a href={`/AI-Koulu/${ch.slug}/`} style="display: flex; align-items: center; gap: 0.3rem; padding: 0.45rem 0.8rem; border-radius: 6px; color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;">
              <span style="font-size: 0.7rem; color: var(--color-brand); min-width: 1.8rem;">{ch.num}</span>
              <span>{ch.title}</span>
            </a>
          ))}
        </div>
      </details>

      <!-- UI/UX-käytännöt -->
      <details style="margin-top: 0.25rem;">
        <summary style="padding: 0.6rem 0.8rem; border-radius: 8px; font-weight: 600; font-size: 0.95rem; cursor: pointer; color: var(--color-text);">🎨 UI/UX-käytännöt</summary>
        <div style="margin-left: 0.5rem; border-left: 2px solid var(--color-border); padding-left: 0.5rem;">
          {uxChapters.map(ch => (
            <a href={`/AI-Koulu/${ch.slug}/`} style="display: flex; align-items: center; gap: 0.3rem; padding: 0.45rem 0.8rem; border-radius: 6px; color: var(--color-text-secondary); text-decoration: none; font-size: 0.85rem;">
              <span style="font-size: 0.7rem; color: var(--color-brand); min-width: 1.8rem;">{ch.num}</span>
              <span>{ch.title}</span>
              {ch.hasDemo && <span style="font-size: 0.7rem; margin-left: auto;" title="Interaktiivinen demo">{ch.hasDemo}</span>}
            </a>
          ))}
        </div>
      </details>

      <a href="/AI-Koulu/haku/" style="display: block; padding: 0.6rem 0.8rem; border-radius: 8px; font-weight: 500; font-size: 0.95rem; color: var(--color-text); text-decoration: none;">🔍 Haku</a>

      <div style="margin-top: 0.5rem; padding-top: 0.5rem; border-top: 1px solid var(--color-border);">
        <button data-theme-btn style="
          width: 100%;
          background: var(--color-bg);
          border: 1px solid var(--color-border);
          border-radius: 8px;
          padding: 0.5rem 1rem;
          cursor: pointer;
          color: var(--color-text);
          font-family: inherit;
          font-size: 0.9rem;
        ">🌓 Vaihda teemaa</button>
      </div>
    </nav>

    <!-- Pääsisältö -->
    <main>
      <slot />
    </main>

    <!-- Alaosa -->
    <footer class="container-wide footer-glass">
      <p>
        <strong>AI & UI/UX Edu</strong> — Interaktiivinen opetussivusto AI-arkkitehtuureista ja UI/UX-käytännöistä.
      </p>
      <p style="margin-top: var(--space-sm);">
        Sisältö perustuu vuoden 2024–2026 tutkimukseen. Lähdeviitteet jokaisen luvun yhteydessä.
      </p>
    </footer>

    <!-- Mobiili-pohjanavigaatio (näkyy vain mobiilissa) -->
    <nav
      aria-label="Mobiilinavigaatio"
      class="mobile-nav"
      style="
        display: none;
        position: fixed;
        bottom: 0;
        left: 0;
        right: 0;
        z-index: 1000;
        background: var(--glass-bg);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-top: 1px solid var(--glass-border);
        padding: 0.25rem 0;
        justify-content: space-around;
        align-items: center;
      "
    >
      <a href="/AI-Koulu/" style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem; color: var(--color-text-muted); text-decoration: none; font-size: clamp(0.6rem, 1.5vw, 0.7rem); padding: 0.5rem; min-width: 48px; min-height: 48px; justify-content: center;">
        <span style="font-size: clamp(1.2rem, 2.5vw, 1.4rem);">🏠</span>
        Etusivu
      </a>
      <a href="/AI-Koulu/ai-architecture/" style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem; color: var(--color-text-muted); text-decoration: none; font-size: clamp(0.6rem, 1.5vw, 0.7rem); padding: 0.5rem; min-width: 48px; min-height: 48px; justify-content: center;">
        <span style="font-size: clamp(1.2rem, 2.5vw, 1.4rem);">🤖</span>
        AI
      </a>
      <a href="/AI-Koulu/agent-patterns/" style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem; color: var(--color-text-muted); text-decoration: none; font-size: clamp(0.6rem, 1.5vw, 0.7rem); padding: 0.5rem; min-width: 48px; min-height: 48px; justify-content: center;">
        <span style="font-size: clamp(1.2rem, 2.5vw, 1.4rem);">🧠</span>
        Agentit
      </a>
      <a href="/AI-Koulu/ui-ux/" style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem; color: var(--color-text-muted); text-decoration: none; font-size: clamp(0.6rem, 1.5vw, 0.7rem); padding: 0.5rem; min-width: 48px; min-height: 48px; justify-content: center;">
        <span style="font-size: clamp(1.2rem, 2.5vw, 1.4rem);">🎨</span>
        UI/UX
      </a>
      <a href="/AI-Koulu/haku/" style="display: flex; flex-direction: column; align-items: center; gap: 0.15rem; color: var(--color-text-muted); text-decoration: none; font-size: clamp(0.6rem, 1.5vw, 0.7rem); padding: 0.5rem; min-width: 48px; min-height: 48px; justify-content: center;">
        <span style="font-size: clamp(1.2rem, 2.5vw, 1.4rem);">🔍</span>
        Haku
      </a>
    </nav>

    <style>
      @media (max-width: 768px) {
        .mobile-nav { display: flex !important; }
        body { padding-bottom: 4rem; }
      }
    </style>

    <script>
      // ---- Teema (toimii aina, ei importteja) ----
      (function() {
        try {
          var stored = localStorage.getItem("ai-edu-theme") || "system";
          var root = document.documentElement;
          if (stored === "system") stored = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          root.setAttribute("data-theme", stored);
        } catch(e) {}
      })();

      // ---- Teemanvaihtaja (data-theme-btn) ----
      document.addEventListener("click", function(e) {
        var btn = e.target.closest("[data-theme-btn]");
        if (!btn) return;
        try {
          var current = localStorage.getItem("ai-edu-theme") || "system";
          var next = { light: "dark", dark: "system", system: "light" }[current] || "light";
          localStorage.setItem("ai-edu-theme", next);
          var root = document.documentElement;
          if (next === "system") next = window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
          root.setAttribute("data-theme", next);
        } catch(e) {}
      });

      // ---- Hampurilaisvalikko ----
      var hb = document.getElementById("hamburger-btn");
      var mm = document.getElementById("mobile-menu");
      var mo = document.getElementById("mobile-menu-overlay");
      var cm = document.getElementById("close-menu");
      if (hb && mm && mo) {
        hb.addEventListener("click", function() { mm.classList.add("open"); mo.classList.add("open"); hb.setAttribute("aria-expanded", "true"); });
        if (cm) cm.addEventListener("click", function() { mm.classList.remove("open"); mo.classList.remove("open"); hb.setAttribute("aria-expanded", "false"); });
        mo.addEventListener("click", function() { mm.classList.remove("open"); mo.classList.remove("open"); hb.setAttribute("aria-expanded", "false"); });
      }

      // ---- Scroll-to-top ----
      var stt = document.getElementById("scroll-to-top");
      window.addEventListener("scroll", function() { if (stt) stt.classList.toggle("visible", window.scrollY > 500); });
      if (stt) stt.addEventListener("click", function() { window.scrollTo({ top: 0, behavior: "smooth" }); });
    </script>
  </body>
</html>
